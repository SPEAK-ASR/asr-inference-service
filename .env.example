# Copy to `.env` and adjust. All variables use the `ASR_` prefix (see `app/core/config.py`).
# PowerShell: Copy-Item .env.example .env

# --- Diarization (required if you enable diarization via POST /admin/diarization) ---
# Hugging Face access token with rights to pyannote/speaker-diarization-community-1.
# Install ffmpeg (pyannote 4.x / torchcodec). Create a token at https://huggingface.co/settings/tokens
# and accept the pipeline user conditions on Hugging Face.
ASR_DIARIZATION_HF_TOKEN=

# --- Model ---
# ASR_BACKEND=transformers
# ASR_MODEL_ID=SPEAK-ASR/whisper-si-exp-10-medium-all
# ASR_TRANSFORMERS_LOAD_MODE=auto
# ASR_LANGUAGE_HINT=si
# ASR_TASK=transcribe
# ASR_MERGE_PEFT_ADAPTER=true

# faster-whisper (CTranslate2) — set ASR_BACKEND=faster_whisper when using
# ASR_BACKEND=faster_whisper
# ASR_MODEL_ID=irudachirath/faster-whisper-medium-si-exp10-fp16
# ASR_FASTER_WHISPER_CUDA_COMPUTE_TYPE=float16
# ASR_FASTER_WHISPER_CPU_COMPUTE_TYPE=int8

# --- Device / precision ---
# ASR_DEVICE=auto
# ASR_CUDA_DTYPE=float16
# ASR_CPU_DTYPE=float32

# --- Audio / streaming ---
# ASR_TARGET_SAMPLE_RATE=16000
# ASR_STREAMING_MODE=vad
# ASR_PARTIAL_INTERVAL_MS=500
# ASR_MAX_BUFFER_SECONDS=30
# ASR_SILENCE_TRIGGER_SECONDS=1.0
# ASR_VAD_THRESHOLD=0.5
# ASR_MIN_SPEECH_SECONDS=0.5
# ASR_DECODE_WINDOW_SECONDS=6.0
# ASR_MIN_AUDIO_FOR_PARTIAL_SECONDS=0.6

# --- Session lifecycle ---
# ASR_IDLE_TIMEOUT_SECONDS=60
# ASR_REAPER_INTERVAL_SECONDS=5

# --- Server ---
# ASR_HOST=0.0.0.0
# ASR_PORT=8000
# ASR_LOG_LEVEL=info

# --- Limits ---
# ASR_MAX_CHUNK_BYTES=262144
