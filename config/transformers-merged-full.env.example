# Example environment for a normal merged / full Hugging Face Whisper checkpoint
# (single repo with pytorch_model.bin or model.safetensors — LoRA merged into base,
# or any native full fine-tune). Skips PEFT adapter detection.
#
# Use this when ASR_MODEL_ID points at a standalone model, not a LoRA-only adapter repo.

ASR_BACKEND=transformers
ASR_TRANSFORMERS_LOAD_MODE=full
ASR_MODEL_ID=your-org/your-merged-whisper-medium-si
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
