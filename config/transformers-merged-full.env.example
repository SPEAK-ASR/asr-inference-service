# Example environment for a single merged / full Hugging Face Whisper checkpoint
# (one repo with safetensors or pytorch_model.bin — not a LoRA-only adapter).
#
# Use this when ASR_MODEL_ID is a standalone ready-to-run model.

ASR_MODEL_KIND=merged
ASR_MODEL_ID=your-org/your-merged-whisper-medium-si
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
ASR_HTTP_TRANSCRIBE_MAX_UPLOAD_BYTES=10485760
ASR_HTTP_TRANSCRIBE_ALLOWED_MIME_TYPES=audio/wav,audio/x-wav,audio/webm,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/aac,audio/ogg
ASR_HTTP_TRANSCRIBE_TIMEOUT_SECONDS=120
