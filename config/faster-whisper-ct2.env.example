# Example environment for faster-whisper (CTranslate2) checkpoints on Hugging Face
# (e.g. model.bin + config.json + tokenizer files).
#
# ASR_MODEL_ID is the Hugging Face repo id or a local directory with the same layout.

ASR_MODEL_KIND=faster_whisper
ASR_MODEL_ID=irudachirath/faster-whisper-medium-si-exp10-fp16
ASR_DEVICE=auto
ASR_FASTER_WHISPER_CUDA_COMPUTE_TYPE=float16
ASR_FASTER_WHISPER_CPU_COMPUTE_TYPE=int8
# ASR_FASTER_WHISPER_BEAM_SIZE=1
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
ASR_HTTP_TRANSCRIBE_MAX_UPLOAD_BYTES=10485760
ASR_HTTP_TRANSCRIBE_ALLOWED_MIME_TYPES=audio/wav,audio/x-wav,audio/webm,audio/mpeg,audio/mp3,audio/mp4,audio/x-m4a,audio/aac,audio/ogg
ASR_HTTP_TRANSCRIBE_TIMEOUT_SECONDS=120
