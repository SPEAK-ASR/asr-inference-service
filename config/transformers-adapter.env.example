# Example environment for Hugging Face Transformers + PEFT/LoRA adapter repo.
# Copy or symlink to the project root as `.env`, or set these variables in your shell.
#
# Base model id is read from adapter_config.json unless you set ASR_BASE_MODEL_ID.
#
# HF_TOKEN is required for gated models (e.g. pyannote diarization pipelines).
# Obtain one at https://hf.co/settings/tokens and accept model conditions on the hub.
# HF_TOKEN=hf_xxxxxxxxxxxx

ASR_MODEL_KIND=peft
ASR_MODEL_ID=SPEAK-ASR/whisper-si-exp-10-medium-all
# ASR_BASE_MODEL_ID=openai/whisper-medium
ASR_MERGE_PEFT_ADAPTER=true
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
