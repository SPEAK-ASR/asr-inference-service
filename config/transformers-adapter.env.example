# Example environment for Hugging Face Transformers + Whisper / PEFT adapters.
# Copy or symlink to the project root as `.env`, or set these variables in your shell.
#
# ASR_MODEL_ID can be a full model repo or an adapter whose config lists
# base_model_name_or_path (e.g. openai/whisper-medium); the loader resolves
# adapters automatically.

ASR_BACKEND=transformers
ASR_MODEL_ID=SPEAK-ASR/whisper-si-exp-10-medium-all
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
