# Example environment for Hugging Face Transformers + PEFT/LoRA adapter repo.
# Copy or symlink to the project root as `.env`, or set these variables in your shell.
#
# Base model id is read from adapter_config.json unless you set ASR_BASE_MODEL_ID.

ASR_MODEL_KIND=peft
ASR_MODEL_ID=SPEAK-ASR/whisper-si-exp-10-medium-all
# ASR_BASE_MODEL_ID=openai/whisper-medium
ASR_MERGE_PEFT_ADAPTER=true
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe

# Optional: pyannote speaker diarization (same for all ASR_MODEL_KIND values).
# Accept the model conditions on Hugging Face, then set a token:
# ASR_HF_TOKEN=hf_...
# Or use HF_TOKEN / HUGGING_FACE_HUB_TOKEN.
# ASR_DIARIZATION_MODEL_ID=pyannote/speaker-diarization-community-1
# ASR_POSTPROCESSING_DIARIZATION_DEFAULT=false
# ASR_POSTPROCESSING_NOISE_REMOVAL_DEFAULT=false
