# Example environment for Hugging Face Transformers + PEFT adapter repos.
# Copy or symlink to the project root as `.env`, or set these variables in your shell.
#
# ASR_TRANSFORMERS_LOAD_MODE=auto: read config.json; if it lists a PEFT base,
# load base + adapter. Use this for adapter checkpoints (e.g. on top of openai/whisper-medium).

ASR_BACKEND=transformers
ASR_TRANSFORMERS_LOAD_MODE=auto
ASR_MODEL_ID=SPEAK-ASR/whisper-si-exp-10-medium-all
ASR_DEVICE=auto
ASR_CUDA_DTYPE=float16
ASR_LANGUAGE_HINT=si
ASR_TASK=transcribe
